    <!-- ============================================================ -->
    <!-- DISPATCH TRAY
         FK drop zone: j1=1.0, j2=-0.55, j3=-0.15
         Position: x=0.664, y=1.034, z=1.216 (gripper height)
         Tray surface at z = 1.216 - 0.06 = 1.156
    -->
    <model name="dispatch_tray">
      <static>true</static>
      <!-- Tray surface at z=1.156 minus tray_thickness/2 -->
      <pose>0.664 1.034 1.147 0 0 1.0</pose>
      <link name="link">
        <!-- Tray base -->
        <collision name="col">
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>0.28 0.20 0.018</size></box></geometry>
        </collision>
        <visual name="base">
          <geometry><box><size>0.28 0.20 0.018</size></box></geometry>
