    <!-- ================================================================== -->
    <!-- RFID SCANNER STATION -->
    <!-- ================================================================== -->
    <model name="rfid_scanner">
      <static>true</static>
      <pose>0.7 0.85 1.1 0 0.1 -0.4</pose>
      <link name="link">
        <visual name="body">
          <geometry>
            <box><size>0.15 0.2 0.05</size></box>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.1 1</ambient>
            <diffuse>0.12 0.12 0.15 1</diffuse>
            <specular>0.35 0.35 0.35 1</specular>
          </material>
        </visual>
        <!-- Antenna area -->
        <visual name="antenna">
          <pose>0 0 0.027 0 0 0</pose>
