          <pose>0 -0.220 1.45 0 0 0</pose>
          <geometry><box><size>0.001 0.12 0.10</size></box></geometry>
          <material><ambient>0.85 0.58 0.08 1</ambient><diffuse>0.95 0.70 0.12 1</diffuse></material>
        </visual>
        <!-- Slot 2 – blue   y=+0.220 -->
        <visual name="s2">
          <pose>0 0.220 1.45 0 0 0</pose>
          <geometry><box><size>0.001 0.12 0.10</size></box></geometry>
          <material><ambient>0.10 0.35 0.80 1</ambient><diffuse>0.18 0.48 0.92 1</diffuse></material>
        </visual>
        <!-- Slot 3 – green  y=+0.642 -->
        <visual name="s3">
          <pose>0 0.642 1.45 0 0 0</pose>
          <geometry><box><size>0.001 0.12 0.10</size></box></geometry>
          <material><ambient>0.10 0.60 0.18 1</ambient><diffuse>0.16 0.75 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

