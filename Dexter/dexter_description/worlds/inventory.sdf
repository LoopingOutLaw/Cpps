      </link>
    </model>

    <!-- RFID scanner stand -->
    <model name="rfid_stand">
      <static>true</static>
      <pose>0.7 0.85 0.55 0 0 0</pose>
      <link name="link">
        <visual name="pole">
          <geometry>
            <cylinder>
              <radius>0.025</radius>
              <length>1.1</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.18 0.18 0.2 1</ambient>
            <diffuse>0.25 0.25 0.28 1</diffuse>
          </material>
        </visual>
        <visual name="base">
          <pose>0 0 -0.53 0 0 0</pose>
