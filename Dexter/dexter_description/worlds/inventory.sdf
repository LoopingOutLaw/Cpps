          <geometry><box><size>0.001 0.12 0.10</size></box></geometry>
          <material><ambient>0.85 0.15 0.10 1</ambient><diffuse>0.95 0.20 0.15 1</diffuse></material>
        </visual>
        <!-- Slot 1 – amber  y=-0.220 -->
