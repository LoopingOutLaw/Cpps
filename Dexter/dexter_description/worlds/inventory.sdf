          </material>
        </visual>
        <!-- Status LED -->
        <visual name="led_green">
          <pose>0.07 0 0.027 0 0 0</pose>
          <geometry>
            <sphere><radius>0.01</radius></sphere>
          </geometry>
          <material>
            <ambient>0.1 0.8 0.15 1</ambient>
