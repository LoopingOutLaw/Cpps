    <!-- ============================================================ -->

    <!-- Slot 0 – Resistors (Red)   j1=-0.55 -->
    <model name="box_slot0">
      <static>true</static>
      <pose>1.048 -0.642 1.156 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 0.12 0.12</size></box></geometry></collision>
