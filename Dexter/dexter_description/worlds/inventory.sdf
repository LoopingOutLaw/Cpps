    <!-- Slot 2 – LEDs (Blue)  j1=+0.18 -->
    <model name="box_slot2">
      <static>true</static>
      <pose>1.209 0.220 1.156 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 0.12 0.12</size></box></geometry></collision>
