<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="inventory_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"           name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"     name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system"           name="gz::sim::systems::Contact"/>

    <scene>
      <ambient>0.6 0.6 0.65 1</ambient>
      <background>0.12 0.14 0.18 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>3 3 10 0 0 0</pose>
      <diffuse>1.0 0.98 0.95 1</diffuse>
      <specular>0.4 0.4 0.4 1</specular>
      <direction>-0.4 -0.2 -0.8</direction>
    </light>

    <light name="fill" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>-3 -3 8 0 0 0</pose>
      <diffuse>0.45 0.48 0.55 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <direction>0.4 0.3 -0.7</direction>
    </light>

    <light name="overhead" type="point">
      <cast_shadows>false</cast_shadows>
      <pose>0.5 0 3.5 0 0 0</pose>
      <diffuse>0.9 0.92 1.0 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>12</range><constant>0.4</constant>
        <linear>0.05</linear><quadratic>0.01</quadratic>
      </attenuation>
    </light>

    <!-- ============================================================ -->
    <!-- FLOOR -->
    <!-- ============================================================ -->
    <model name="warehouse_floor">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>10 10</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>10 10</size></plane></geometry>
          <material>
            <ambient>0.22 0.23 0.25 1</ambient>
            <diffuse>0.32 0.33 0.36 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Safety circle around robot -->
    <model name="safety_zone">
      <static>true</static>
      <pose>0 0 0.003 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><cylinder><radius>1.5</radius><length>0.004</length></cylinder></geometry>
          <material><ambient>0.7 0.55 0.0 1</ambient><diffuse>0.85 0.7 0.05 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- INVENTORY SHELF
         FK analysis (URDF joints, pick pose j2=-0.55, j3=-0.15):
           Gripper reaches z = 1.216 m, radius ~1.23 m (arm extended far)

         Exact box centres (gripper at z=1.216, box centre 0.06m below):
           Slot 0  j1=-0.55  x= 1.048  y=-0.642  z=1.156
           Slot 1  j1=-0.18  x= 1.209  y=-0.220  z=1.156
           Slot 2  j1=+0.18  x= 1.209  y=+0.220  z=1.156
           Slot 3  j1=+0.55  x= 1.048  y=+0.642  z=1.156

         Shelf surface: z = 1.156 - 0.06 (box half) = 1.096 m
         Shelf located at arc centre ≈ x=1.13, y=0
    -->

    <!-- Shelf main surface (flat approximation of the arc, centred at arc midpoint) -->
    <model name="shelf_surface">
      <static>true</static>
      <pose>1.13 0 1.096 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.25 1.45 0.025</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.25 1.45 0.025</size></box></geometry>
          <material>
            <ambient>0.42 0.36 0.28 1</ambient>
            <diffuse>0.58 0.50 0.40 1</diffuse>
            <specular>0.10 0.10 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Back wall of shelf -->
    <model name="shelf_back">
      <static>true</static>
      <pose>1.30 0 1.37 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>0.04 1.45 0.58</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.04 1.45 0.58</size></box></geometry>
          <material>
            <ambient>0.28 0.24 0.20 1</ambient>
            <diffuse>0.38 0.32 0.26 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Left side wall -->
    <model name="shelf_side_left">
      <static>true</static>
      <pose>1.13 -0.720 1.37 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.25 0.03 0.58</size></box></geometry>
          <material><ambient>0.25 0.22 0.18 1</ambient><diffuse>0.35 0.30 0.24 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Right side wall -->
    <model name="shelf_side_right">
      <static>true</static>
      <pose>1.13 0.720 1.37 0 0 0</pose>
      <link name="link">
        <visual name="vis">
          <geometry><box><size>0.25 0.03 0.58</size></box></geometry>
          <material><ambient>0.25 0.22 0.18 1</ambient><diffuse>0.35 0.30 0.24 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Slot dividers on shelf -->
    <model name="shelf_dividers">
      <static>true</static>
      <pose>1.13 0 0 0 0 0</pose>
      <link name="link">
        <!-- Divider between slot 0 and slot 1  (y ≈ -0.43) -->
        <visual name="d01">
          <pose>0 -0.43 1.32 0 0 0</pose>
          <geometry><box><size>0.24 0.015 0.45</size></box></geometry>
          <material><ambient>0.32 0.28 0.22 1</ambient><diffuse>0.42 0.36 0.28 1</diffuse></material>
        </visual>
        <!-- Divider between slot 1 and slot 2  (y = 0) -->
        <visual name="d12">
          <pose>0 0 1.32 0 0 0</pose>
          <geometry><box><size>0.24 0.015 0.45</size></box></geometry>
          <material><ambient>0.32 0.28 0.22 1</ambient><diffuse>0.42 0.36 0.28 1</diffuse></material>
        </visual>
        <!-- Divider between slot 2 and slot 3  (y ≈ +0.43) -->
        <visual name="d23">
          <pose>0 0.43 1.32 0 0 0</pose>
          <geometry><box><size>0.24 0.015 0.45</size></box></geometry>
          <material><ambient>0.32 0.28 0.22 1</ambient><diffuse>0.42 0.36 0.28 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Coloured slot ID strips on back wall (one per slot) -->
    <model name="slot_id_strips">
